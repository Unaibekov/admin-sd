<%- include('partials/head', { pageTitle }) %>
<%
  const reportSummary = report.summary || {};
  const cards = Array.isArray(report.cards) ? report.cards : [];
  const visiblePlantParts = (parts) => parts.filter((part) => {
    const text = String(part || '').trim();
    return text && text.toLowerCase() !== 'отсутствует';
  });
  const problemCards = cards.filter((card) => Boolean(card.problem || card.risk || (card.events || []).some((event) => event.problem || event.risk || event.problemType || event.riskLevel)));
  const stageMap = new Map();
  for (const card of cards) {
    const key = card.stage || card.batchStatus || 'Без стадии';
    const current = stageMap.get(key) || 0;
    stageMap.set(key, current + 1);
  }
  const stageEntries = [...stageMap.entries()].sort((left, right) => right[1] - left[1]);
  const stageTotal = cards.length || 1;
  const stagePalette = ['#2f855a', '#3b82f6', '#f59e0b', '#8b5cf6', '#ef4444', '#14b8a6', '#64748b'];
  let stageStart = 0;
  const stageSlices = stageEntries.map(([label, value], index) => {
    const percent = (value / stageTotal) * 100;
    const slice = {
      label,
      value,
      color: stagePalette[index % stagePalette.length],
      start: stageStart,
      end: stageStart + percent
    };
    stageStart += percent;
    return slice;
  });
  const chartBackground = stageSlices.length
    ? `conic-gradient(${stageSlices.map((slice) => `${slice.color} ${slice.start.toFixed(2)}% ${slice.end.toFixed(2)}%`).join(', ')})`
    : 'conic-gradient(#e5e7eb 0 100%)';
  const recentCards = cards.slice(0, 8);
%>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: 'report', showDashboardLink: true }) %>

  <main class="app-main app-main-report">
    <section class="report-page">
      <header class="report-header">
        <div class="report-header-top">
          <a href="/" class="report-back-link">← Назад к отчетам</a>
          <div class="report-actions">
            <a href="/reports/<%= encodeURIComponent(report.reportId) %>/zip" class="button button-secondary">Скачать ZIP</a>
            <a href="/reports/<%= encodeURIComponent(report.reportId) %>/raw" class="button button-secondary">Скачать JSON</a>
          </div>
        </div>

        <div class="report-title-row">
          <div class="report-title-copy">
            <p class="eyebrow">Отчет</p>
            <h1><%= report.reportId %></h1>
            <div class="report-status-row">
              <span class="report-status-pill report-status-pill-success">Загружен</span>
              <span class="report-status-muted"><%= report.displayCreatedAt %></span>
            </div>
          </div>

          <div class="report-user-card">
            <div class="report-user-avatar"><%= (report.user && report.user.displayName ? report.user.displayName : 'A').charAt(0).toUpperCase() %></div>
            <div>
              <strong><%= report.user && report.user.displayName ? report.user.displayName : 'Автор не указан' %></strong>
              <span><%= report.user && report.user.role ? report.user.role : 'Администратор' %></span>
            </div>
          </div>
        </div>

        <div class="report-meta-row">
          <div>
            <span>Автор</span>
            <strong><%= report.user && report.user.displayName ? report.user.displayName : 'Автор не указан' %></strong>
          </div>
          <div>
            <span>Устройство</span>
            <strong><%= report.deviceId || 'Не указано' %></strong>
          </div>
          <div>
            <span>Место</span>
            <strong><%= report.testLocation || 'Не указано' %></strong>
          </div>
          <div>
            <span>Создан</span>
            <strong><%= report.displayCreatedAt %></strong>
          </div>
        </div>
      </header>

      <section class="report-stats-grid">
        <article class="report-stat report-stat-primary">
          <span>Партии</span>
          <strong><%= reportSummary.cardsCount || 0 %></strong>
          <small>+<%= Math.max((reportSummary.cardsCount || 0) - 1, 0) %> за период</small>
        </article>
        <article class="report-stat report-stat-blue">
          <span>События</span>
          <strong><%= reportSummary.eventsCount || 0 %></strong>
          <small>+<%= Math.max((reportSummary.eventsCount || 0) - cards.length, 0) %> за период</small>
        </article>
        <article class="report-stat report-stat-orange">
          <span>Проблемы</span>
          <strong><%= reportSummary.problemsCount || 0 %></strong>
          <small>+<%= reportSummary.lossCount || 0 %> потерь</small>
        </article>
        <article class="report-stat report-stat-purple">
          <span>Фото</span>
          <strong><%= reportSummary.photosCount || 0 %></strong>
          <small>+<%= Math.max((reportSummary.photosCount || 0) - 0, 0) %> за период</small>
        </article>
      </section>

      <section class="report-layout">
        <div class="report-main-column">
          <section class="report-panel report-filters-panel">
            <div class="report-panel-head">
              <div>
                <h2>Поиск партий</h2>
                <p>Фильтруйте список по коду, стадии, культуре и статусу.</p>
              </div>
              <a class="text-link" href="/reports/<%= encodeURIComponent(report.reportId) %>">Сбросить фильтры</a>
            </div>

            <form class="report-filters" method="get">
              <input type="search" name="q" placeholder="Введите код или название партии" value="<%= filters.q %>" />
              <select name="stage">
                <option value="">Все стадии</option>
                <% report.filterOptions.stages.forEach((option) => { %>
                  <option value="<%= option %>" <%= filters.stage === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
              <select name="culture">
                <option value="">Все культуры</option>
                <% report.filterOptions.cultures.forEach((option) => { %>
                  <option value="<%= option %>" <%= filters.culture === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>
              <select name="status">
                <option value="">Все статусы</option>
                <% report.filterOptions.statuses.forEach((option) => { %>
                  <option value="<%= option %>" <%= filters.status === option ? 'selected' : '' %>><%= option %></option>
                <% }) %>
              </select>

              <label class="check-pill">
                <input type="checkbox" name="hasProblems" value="1" <%= filters.hasProblems === '1' ? 'checked' : '' %> />
                Только с проблемами
              </label>
              <label class="check-pill">
                <input type="checkbox" name="hasPhotos" value="1" <%= filters.hasPhotos === '1' ? 'checked' : '' %> />
                Только с фото
              </label>
              <button class="button" type="submit">Применить</button>
            </form>
          </section>

          <section class="report-panel report-cards-panel">
            <div class="report-panel-head report-panel-head-compact">
              <div>
                <h2>Партии (<%= cards.length %>)</h2>
                <p>Под текущие фильтры подходит <%= cards.length %> партий.</p>
              </div>
            </div>

            <% if (!cards.length) { %>
              <div class="empty-state report-empty-state">
                <h3>Подходящих партий нет</h3>
                <p>Попробуйте сбросить фильтры или изменить запрос.</p>
              </div>
            <% } else { %>
              <div class="report-cards-grid">
                <% cards.forEach((card) => { %>
                  <% const coverPhoto = card.photos && card.photos.length ? card.photos[0] : (card.events || []).flatMap((event) => event.photos || [])[0] || ''; %>
                  <% const lastEvent = (card.events || []).slice().sort((left, right) => new Date(right.createdAt || right.date || 0).getTime() - new Date(left.createdAt || left.date || 0).getTime())[0] || null; %>
                  <article class="report-card">
                    <div class="report-card-top">
                      <div class="report-card-main">
                        <span class="report-card-code"><%= card.code %></span>
                        <h3><%= visiblePlantParts([card.cultureName, card.speciesName, card.varietyName]).join(' · ') || 'Без названия' %></h3>
                        <div class="report-card-badges">
                          <% if (card.stage) { %><span class="badge badge-muted"><%= card.stage %></span><% } %>
                          <% if (card.batchStatus) { %><span class="badge"><%= card.batchStatus %></span><% } %>
                          <% if (card.sterilityStatus) { %><span class="badge badge-muted"><%= card.sterilityStatus %></span><% } %>
                        </div>
                      </div>
                      <% if (coverPhoto) { %>
                        <button type="button" class="report-card-photo" data-photo-url="<%= report.getPhotoUrl(coverPhoto) %>" data-photo-label="<%= card.code %>">
                          <img src="<%= report.getPhotoUrl(coverPhoto) %>" alt="<%= card.code %>" loading="lazy" />
                        </button>
                      <% } %>
                    </div>

                    <dl class="report-card-meta">
                      <div><dt>Количество</dt><dd><%= card.quantity || '—' %></dd></div>
                      <div><dt>Остаток</dt><dd><%= card.currentQuantity || '—' %></dd></div>
                      <div><dt>Стадия</dt><dd><%= card.stage || '—' %></dd></div>
                      <div><dt>Место</dt><dd><%= card.locationDescription || '—' %></dd></div>
                    </dl>

                    <% if (lastEvent) { %>
                      <div class="report-card-event">
                        <span>Последнее событие</span>
                        <strong><%= lastEvent.title || lastEvent.type %></strong>
                        <p><%= lastEvent.date || 'Дата не указана' %></p>
                      </div>
                    <% } %>

                    <% if ((card.problem || card.risk || (card.events || []).some((event) => event.problem || event.risk || event.problemType || event.riskLevel))) { %>
                      <div class="report-card-alert">
                        <strong>Проблема</strong>
                        <p><%= card.problem || card.risk || 'Требует внимания' %></p>
                      </div>
                    <% } %>

                    <div class="report-card-footer">
                      <span><%= (card.events || []).length %> событий</span>
                      <a href="/reports/<%= encodeURIComponent(report.reportId) %>?q=<%= encodeURIComponent(card.code) %>" class="report-card-link">Открыть →</a>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } %>
          </section>
        </div>

        <aside class="report-sidebar">
          <section class="report-panel report-aside-panel">
            <div class="report-panel-head">
              <div>
                <h2>Проблемные партии</h2>
              </div>
              <a class="text-link" href="/reports/<%= encodeURIComponent(report.reportId) %>?hasProblems=1">Смотреть все</a>
            </div>

            <% if (problemCards.length) { %>
              <div class="report-side-list">
                <% problemCards.slice(0, 5).forEach((card) => { %>
                  <article class="report-side-item">
                    <div class="report-side-photo">
                      <% const sidePhoto = card.photos && card.photos.length ? card.photos[0] : ''; %>
                      <% if (sidePhoto) { %>
                        <img src="<%= report.getPhotoUrl(sidePhoto) %>" alt="<%= card.code %>" loading="lazy" />
                      <% } %>
                    </div>
                    <div class="report-side-copy">
                      <strong><%= card.code %></strong>
                      <span><%= visiblePlantParts([card.cultureName, card.speciesName]).join(' · ') || 'Без названия' %></span>
                      <div class="report-side-badges">
                        <% if (card.risk) { %><span class="badge badge-muted"><%= card.risk %></span><% } %>
                        <% if (card.stage) { %><span class="badge badge-muted"><%= card.stage %></span><% } %>
                      </div>
                    </div>
                    <span class="report-side-arrow">›</span>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <div class="empty-state report-empty-state report-empty-state-aside">
                <h3>Проблемных партий нет</h3>
                <p>Если появятся проблемные карточки, они отобразятся здесь.</p>
              </div>
            <% } %>
          </section>

          <section class="report-panel report-aside-panel">
            <div class="report-panel-head">
              <div>
                <h2>Сводка по стадиям</h2>
              </div>
              <a class="text-link" href="/reports/<%= encodeURIComponent(report.reportId) %>">Смотреть все</a>
            </div>

            <div class="report-stage-chart-wrap">
              <div class="report-stage-chart" style="background: <%= chartBackground %>;">
                <div>
                  <strong><%= cards.length %></strong>
                  <span>Всего</span>
                </div>
              </div>
              <div class="report-stage-legend">
                <% stageSlices.slice(0, 6).forEach((slice) => { %>
                  <div>
                    <span class="report-stage-dot" style="background:<%= slice.color %>"></span>
                    <strong><%= slice.label %></strong>
                    <em><%= slice.value %> (<%= Math.round((slice.value / stageTotal) * 100) %>%)</em>
                  </div>
                <% }) %>
              </div>
            </div>
          </section>

          <section class="report-panel report-aside-panel">
            <div class="report-panel-head">
              <div>
                <h2>Недавние партии</h2>
              </div>
            </div>
            <div class="report-recent-list">
              <% recentCards.forEach((card) => { %>
                <article class="report-recent-item">
                  <strong><%= card.code %></strong>
                  <span><%= visiblePlantParts([card.cultureName, card.speciesName, card.varietyName]).join(' · ') || 'Без названия' %></span>
                </article>
              <% }) %>
            </div>
          </section>
        </aside>
      </section>
    </section>
  </main>
</div>

<div class="lightbox" hidden>
  <button class="lightbox-backdrop" type="button" aria-label="Закрыть предпросмотр"></button>
  <figure class="lightbox-panel">
    <button class="lightbox-close" type="button" aria-label="Закрыть предпросмотр">×</button>
    <img class="lightbox-image" alt="" />
    <figcaption class="lightbox-caption"></figcaption>
  </figure>
</div>

<script>
  window.__REPORT_ID__ = <%- JSON.stringify(report.reportId) %>;
</script>
<%- include('partials/footer') %>
