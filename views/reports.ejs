<%- include('partials/head', { pageTitle }) %>
<%
  const employees = Array.isArray(reportsPage && reportsPage.employees) ? reportsPage.employees : [];
  const selectedEmployee = reportsPage && reportsPage.selectedEmployee ? reportsPage.selectedEmployee : null;
  const selectedEmployeeKey = reportsPage && reportsPage.selectedEmployeeKey ? reportsPage.selectedEmployeeKey : '';
  const selectedReportData = typeof selectedReport !== 'undefined' ? selectedReport : null;
  const reportCards = selectedReportData && Array.isArray(selectedReportData.cards) ? selectedReportData.cards : [];
  const reportCardStatusOrder = ['all', 'active', 'partial', 'sold', 'quarantine', 'archived', 'problem', 'other'];
  const reportCardStatusLabels = {
    all: 'Все',
    active: 'Активная',
    partial: 'Частичная',
    sold: 'Продано',
    quarantine: 'Карантин',
    archived: 'Архив',
    problem: 'Проблема',
    other: 'Статус'
  };

  const formatDaysInStage = (value) => {
    if (!value) {
      return '—';
    }

    const start = new Date(value);
    if (Number.isNaN(start.getTime())) {
      return '—';
    }

    const now = new Date();
    const startUtc = Date.UTC(start.getUTCFullYear(), start.getUTCMonth(), start.getUTCDate());
    const nowUtc = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
    const days = Math.max(0, Math.floor((nowUtc - startUtc) / 86400000));
    const lastTwoDigits = days % 100;
    const lastDigit = days % 10;

    if (lastTwoDigits >= 11 && lastTwoDigits <= 14) {
      return `${days} дней в стадии`;
    }

    if (lastDigit === 1) {
      return `${days} день в стадии`;
    }

    if (lastDigit >= 2 && lastDigit <= 4) {
      return `${days} дня в стадии`;
    }

    return `${days} дней в стадии`;
  };

  const formatQuantity = (card) => {
    const quantity = String(card.currentQuantity || card.quantity || '').trim();
    const initial = String(card.quantity || '').trim();

    if (!quantity) {
      return '—';
    }

    if (initial && initial !== quantity) {
      return `${quantity} из ${initial} шт.`;
    }

    return `${quantity} шт.`;
  };

  const hasProblemSignals = (card) => Boolean(
    card && (
      card.problem ||
      card.problemType ||
      card.risk ||
      card.riskLevel ||
      String(card.sterilityStatus || '').toLowerCase().includes('contamin') ||
      String(card.batchStatus || card.status || '').toLowerCase().includes('problem') ||
      String(card.batchStatus || card.status || '').toLowerCase().includes('risk') ||
      String(card.batchStatus || card.status || '').toLowerCase().includes('quarantine') ||
      (Array.isArray(card.events) && card.events.some((event) => event.problem || event.problemType || event.risk || event.riskLevel))
    )
  );

  const resolveCardStatus = (card) => {
    const rawStatus = String(card && (card.batchStatus || card.status || '')).trim().toLowerCase();

    if (hasProblemSignals(card)) {
      return 'problem';
    }
    if (rawStatus.includes('quarantine')) {
      return 'quarantine';
    }
    if (rawStatus.includes('sold')) {
      return 'sold';
    }
    if (rawStatus.includes('partial')) {
      return 'partial';
    }
    if (rawStatus.includes('archiv')) {
      return 'archived';
    }
    if (rawStatus.includes('active')) {
      return 'active';
    }

    return rawStatus || 'other';
  };

  const buildCardSearchText = (card) => [
    card.code,
    card.cultureName,
    card.speciesName,
    card.varietyName,
    card.stage,
    card.locationDescription,
    card.batchStatus,
    card.status,
    card.sterilityStatus,
    card.problem,
    card.risk,
    card.problemType,
    card.riskLevel,
    reportCardStatusLabels[resolveCardStatus(card)] || ''
  ]
    .filter(Boolean)
    .join(' ')
    .toLowerCase();

  const buildCardTitle = (card) => [card.cultureName, card.speciesName, card.varietyName].filter(Boolean).join(' · ') || card.code || 'Без названия';
  const buildCardStatusLabel = (card) => reportCardStatusLabels[resolveCardStatus(card)] || 'Активная';
  const buildCardNote = (card) => {
    if (card.problem || card.problemType) {
      return card.problem || card.problemType;
    }

    if (card.risk || card.riskLevel) {
      return card.risk || card.riskLevel;
    }

    const sterility = String(card.sterilityStatus || '').trim();
    if (sterility && !['sterile', 'нормальный', 'normal', 'unchecked'].includes(sterility.toLowerCase())) {
      return sterility;
    }

    const status = resolveCardStatus(card);
    if (status === 'active') {
      return card.stage || 'Активная';
    }

    return buildCardStatusLabel(card);
  };

  const cardFilterCounts = new Map(reportCardStatusOrder.map((key) => [key, 0]));
  reportCards.forEach((card) => {
    const statusKey = resolveCardStatus(card);
    cardFilterCounts.set(statusKey, (cardFilterCounts.get(statusKey) || 0) + 1);
  });
  const reportCardFilters = reportCardStatusOrder
    .filter((key) => key === 'all' || (cardFilterCounts.get(key) || 0) > 0)
    .map((key) => ({
      key,
      label: reportCardStatusLabels[key] || key,
      count: key === 'all' ? reportCards.length : (cardFilterCounts.get(key) || 0)
    }));
%>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage, showDashboardLink }) %>

  <main class="app-main app-main-reports">
    <section class="reports-page" data-reports-page>
      <header class="reports-hero app-page-hero">
        <div class="reports-hero-copy">
          <h1>Отчеты</h1>
        </div>
      </header>

      <section class="reports-layout">
        <aside class="reports-sidebar-column">
          <section class="journal-panel reports-list-panel">
            <% if (employees.length) { %>
              <div class="reports-employee-list">
                <% employees.forEach((employee) => { %>
                  <a
                    class="journal-card reports-employee-card <%= employee.key === selectedEmployeeKey ? 'active' : '' %>"
                    href="/reports?employee=<%= encodeURIComponent(employee.key) %>"
                  >
                    <div class="journal-card-button reports-employee-card-button">
                      <div class="journal-card-top">
                        <div class="journal-card-heading">
                          <h3><%= employee.label %></h3>
                          <span><%= employee.latestReportDate || 'Дата не указана' %></span>
                        </div>
                        <div class="journal-card-badge">
                          <span><%= employee.reportCount %></span>
                        </div>
                      </div>

                      <div class="journal-card-meta-row reports-employee-meta">
                        <span class="journal-card-meta-item">
                          <span class="journal-card-meta-line">
                            <strong><%= employee.cardsCount %> карточек</strong>
                          </span>
                        </span>
                        <span class="journal-card-meta-item">
                          <span class="journal-card-meta-line">
                            <strong><%= employee.eventsCount %> событий</strong>
                          </span>
                        </span>
                        <span class="journal-card-meta-item">
                          <span class="journal-card-meta-line">
                            <strong><%= employee.photosCount %> фото</strong>
                          </span>
                        </span>
                      </div>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <div class="empty-state reports-empty-state">
                <h3>Отчетов пока нет</h3>
                <p>Загрузите первый ZIP-архив, чтобы сотрудники и их отчеты появились в списке.</p>
              </div>
            <% } %>
          </section>
        </aside>

        <section class="journal-panel reports-detail-panel">
          <% if (selectedEmployee) { %>
            <div class="reports-detail-head">
              <div class="reports-detail-copy">
                <h2><%= selectedEmployee.label %></h2>
                <p><%= selectedReportData && selectedReportData.displayCreatedAt ? selectedReportData.displayCreatedAt : `${selectedEmployee.reportCount} отчетов` %></p>
              </div>
              <div class="dashboard-report-pills reports-detail-pills">
                <span><%= selectedReportData && selectedReportData.summary ? selectedReportData.summary.cardsCount : selectedEmployee.cardsCount %> карточек</span>
                <span><%= selectedReportData && selectedReportData.summary ? selectedReportData.summary.eventsCount : selectedEmployee.eventsCount %> событий</span>
                <span><%= selectedReportData && selectedReportData.summary ? selectedReportData.summary.photosCount : selectedEmployee.photosCount %> фото</span>
              </div>
            </div>

            <% if (reportCards.length) { %>
              <div class="reports-card-toolbar">
                <label class="reports-search">
                  <input
                    type="search"
                    placeholder="Поиск по названию"
                    data-reports-search
                  />
                </label>

                <div class="reports-card-filters" data-reports-card-filters>
                  <% reportCardFilters.forEach((filter) => { %>
                    <button type="button" class="reports-card-filter <%= filter.key === 'all' ? 'active' : '' %>" data-reports-filter="<%= filter.key %>">
                      <% if (filter.key !== 'all') { %>
                        <span class="reports-card-filter-dot reports-card-filter-dot-<%= filter.key %>"></span>
                      <% } %>
                      <span class="reports-card-filter-label"><%= filter.label %></span>
                      <span class="reports-card-filter-count" <%= filter.key === 'all' ? 'data-reports-filter-count' : '' %>><%= filter.count %></span>
                    </button>
                  <% }) %>
                </div>
              </div>

              <div class="reports-card-list" data-reports-card-list>
                <% reportCards.forEach((card) => { %>
                  <% const statusKey = resolveCardStatus(card); %>
                  <% const hasProblem = statusKey === 'problem'; %>
                  <% const noteText = buildCardNote(card); %>
                  <a
                    class="reports-card <%= hasProblem ? 'is-problem' : 'is-active' %>"
                    href="/reports/<%= encodeURIComponent(selectedReportData.reportId) %>?q=<%= encodeURIComponent(card.code) %>"
                    data-reports-card
                    data-reports-card-status="<%= statusKey %>"
                    data-reports-card-search="<%= buildCardSearchText(card) %>"
                  >
                    <div class="reports-card-top">
                      <div class="reports-card-title">
                        <h3><%= buildCardTitle(card) %></h3>
                        <span><%= card.stage || 'Без стадии' %></span>
                      </div>
                      <div class="reports-card-dots">
                        <span class="reports-card-dot reports-card-dot-status reports-card-dot-status-<%= statusKey %>"></span>
                        <% if (hasProblem) { %>
                          <span class="reports-card-dot reports-card-dot-problem"></span>
                        <% } %>
                      </div>
                    </div>

                    <div class="reports-card-meta">
                      <div class="reports-card-meta-item">
                        <svg class="reports-card-meta-icon reports-card-meta-icon-quantity" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                          <path d="M12 3C8 5.4 6 8.9 6 12.2C6 16.1 8.9 20 12 20C15.1 20 18 16.1 18 12.2C18 8.9 16 5.4 12 3Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"></path>
                          <path d="M12 8V17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                        </svg>
                        <span><%= formatQuantity(card) %></span>
                      </div>
                      <div class="reports-card-meta-item">
                        <svg class="reports-card-meta-icon reports-card-meta-icon-days" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2"></circle>
                          <path d="M12 7v5l3 2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                        <span><%= formatDaysInStage(card.date || card.createdAt || selectedReportData.createdAt) %></span>
                      </div>
                    </div>

                    <div class="reports-card-note <%= hasProblem ? 'is-problem' : 'is-info' %>">
                      <span class="reports-card-note-icon"></span>
                      <span><%= noteText %></span>
                    </div>
                  </a>
                <% }) %>
              </div>
            <% } else { %>
              <div class="empty-state reports-empty-state">
                <h3>Карточек нет</h3>
                <p>В выбранном отчете пока нет карточек.</p>
              </div>
            <% } %>
          <% } else { %>
            <div class="reports-detail-placeholder">
              <h2>Выберите сотрудника слева</h2>
              <p>Здесь появится список его отчетов.</p>
            </div>
          <% } %>
        </section>
      </section>
    </section>
  </main>
</div>
<%- include('partials/footer') %>
