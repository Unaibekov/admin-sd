<%- include('partials/head', { pageTitle }) %>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: dashboard.hasReports ? 'dashboard' : 'upload', showDashboardLink: dashboard.hasReports }) %>

  <main class="app-main <%= dashboard.hasReports ? 'app-main-dashboard' : 'app-main-upload' %>">
    <% if (flashMessage) { %><div class="alert alert-success dashboard-flash"><%= flashMessage %></div><% } %>

    <% if (!dashboard.hasReports) { %>
      <section class="dashboard-empty-copy">
        <p class="eyebrow">Дашборд</p>
        <h1>Нет данных для дашборда</h1>
        <p>Загрузите первый ZIP-отчет из Sadovnik Diary.</p>
        <a class="button button-primary" href="/upload">Загрузить отчет</a>
      </section>
    <% } else { %>
      <% const dashboardUrl = (period) => `/?period=${encodeURIComponent(period)}`; %>
      <% const metricIcon = (key) => {
        const icons = {
          active: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21V10m0 5c-4.2 0-7-2.5-7-6.8C8.6 8.2 11 10.7 12 15Zm0-9.5c.9-3 3.2-4.5 6.8-4.5 0 3.9-2.4 6.5-6.8 6.5Z"/></svg>',
          attention: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 2.8 20h18.4L12 3Zm0 6v4m0 3h.01"/></svg>',
          quarantine: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 5 6v5c0 4.7 2.9 8.2 7 10 4.1-1.8 7-5.3 7-10V6l-7-3Zm-3 9h6m-3-3v6"/></svg>',
          losses: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M7 6v12m10-12v12M5 18h14M9 10l3 3 3-3"/></svg>',
          employees: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 20v-1.5c0-2-1.8-3.5-4-3.5s-4 1.5-4 3.5V20m4-9a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm6 9v-1.5c0-1.4-.8-2.6-2-3.2M17 5.2a3 3 0 0 1 0 5.6M6 15.3a3.5 3.5 0 0 0-2 3.2V20"/></svg>'
        };
        return icons[key] || icons.active;
      }; %>
      <% const eventDetails = (event) => {
        const items = [];
        const push = (label, value, suffix = '') => {
          const text = typeof value === 'number' ? String(value) : String(value || '').trim();
          if (text) items.push(`${label}: ${text}${suffix}`);
        };

        if (['loss', 'introloss', 'death', 'discard', 'writeoff'].includes(event.type) && event.quantity) {
          push('Потеряно', event.quantity, ' шт.');
          push('Было', event.previousQuantity, ' шт.');
          push('Остаток', event.currentQuantity, ' шт.');
          push('Причина', event.reason);
        } else if (event.type === 'sale') {
          push('Продано', event.quantity, ' шт.');
          push('Было', event.previousQuantity || event.totalQuantity, ' шт.');
          push('Остаток', event.currentQuantity, ' шт.');
          push('Тип реализации', event.saleType);
          push('Получатель', event.recipient);
          push('Стоимость', event.saleAmount);
          push('Комментарий', event.comment);
        } else if (event.type === 'propagation') {
          push('Размножено', event.quantity, ' шт.');
          push('Остаток', event.currentQuantity, ' шт.');
          push('Способ размножения', event.propagationMethod);
          push('Комментарий', event.comment);
        } else if (event.type === 'rooting') {
          push('Количество', event.quantity ? `${event.quantity}${event.totalQuantity ? ` из ${event.totalQuantity}` : ''}` : '', ' шт.');
          push('Комментарий', event.comment);
        } else if (['adaptationcare', 'greenhousecare', 'hardeningcare', 'plantingcare'].includes(event.type)) {
          push('Тип ухода', event.careType);
          push('Препарат', event.productName);
          push('Дозировка', event.dosage);
          push('Способ внесения', event.applicationMethod);
          push('Реакция растений', event.plantReaction);
          push('Комментарий', event.comment);
        } else if (['adaptationstress', 'greenhouseobservation', 'hardeningobservation', 'plantingobservation'].includes(event.type)) {
          push('Уровень стресса', event.stressLevel);
          push('Тургор', event.turgor);
          push('Комментарий', event.comment);
        } else if (event.type === 'transplant') {
          push('Количество', event.quantity, ' шт.');
          push('Размещение', event.placement);
          push('Плотность', event.densityChange);
          push('Комментарий', event.comment);
        } else if (event.type === 'plantingcompletion') {
          push('Итог высадки', event.completionResult);
          push('Комментарий', event.comment);
        } else if (event.type === 'planting') {
          push('Высажено', event.quantity, ' шт.');
          push('Место высадки', event.plantingLocation);
          push('Схема посадки', event.plantingScheme);
          push('Площадь / участок', event.plotArea);
          push('Тип грунта', event.soilType);
          push('Комментарий', event.comment);
        } else if (event.type === 'movement') {
          push('Местоположение', event.location);
          push('Комментарий', event.comment);
        } else if (event.type === 'stagechange') {
          if (event.fromStage && event.toStage) push('Стадия', `${event.fromStage} → ${event.toStage}`);
          push('Остаток', event.currentQuantity, ' шт.');
        } else if (event.type === 'problem') {
          push('Тип проблемы', event.problem);
          push('Уровень риска', event.risk);
          push('Описание проблемы', event.problemDescription);
        } else if (event.risk) {
          push('Риск', event.risk);
        } else if (event.comment) {
          push('Комментарий', event.comment);
        }

        return items;
      }; %>
      <% const isLongEventDetail = (text) => String(text || '').length > 42; %>
      <% const dashboardTimeZone = 'Europe/Moscow'; %>

      <section class="dashboard-page">
        <div class="dashboard-shell">
          <header class="dashboard-overview-head">
            <div>
              <h1>Дашборд</h1>
              <p>Текущее состояние партий и активность команды.</p>
            </div>
            <nav class="dashboard-period-switcher" aria-label="Период дашборда">
              <% dashboard.periodOptions.forEach((option) => { %>
                <a href="<%= dashboardUrl(option.value) %>" class="<%= dashboard.period.key === option.value ? 'active' : '' %>"><%= option.label %></a>
              <% }) %>
            </nav>
          </header>

          <section class="dashboard-stats dashboard-stats-top" aria-label="Основные показатели">
            <% dashboard.topMetrics.forEach((metric) => { %>
              <% const tag = metric.href ? 'a' : 'article'; %>
              <<%= tag %> class="dashboard-stat dashboard-stat-<%= metric.tone %>" <%= metric.href ? `href="${metric.href}"` : '' %>>
                <span class="dashboard-stat-icon"><%- metricIcon(metric.key) %></span>
                <span class="dashboard-stat-label"><%= metric.label %></span>
                <strong><%= metric.value %></strong>
                <small><%= metric.note %></small>
              </<%= tag %>>
            <% }) %>
          </section>

          <section class="dashboard-layout">
            <article class="dashboard-card dashboard-recent-events-card">
              <div class="dashboard-card-head">
                <div><h2>Последние события</h2><p>Действия сотрудников за период</p></div>
                <a class="dashboard-card-link" href="/journal">Показать все</a>
              </div>
              <% if (dashboard.recentEvents.length) { %>
                <div class="dashboard-event-feed">
                  <% dashboard.recentEvents.forEach((event) => { %>
                    <% const eventUrl = event.cardId ? `/stages?cardId=${encodeURIComponent(event.cardId)}&tab=journal${event.eventId ? `&eventId=${encodeURIComponent(event.eventId)}` : ''}#journal` : ''; %>
                    <% const eventIsAttention = ['problem', 'quarantine', 'contamination', 'greenhousedisease'].includes(event.type) || event.problem || event.risk; %>
                    <% const eventRowClass = `dashboard-event-row${eventIsAttention ? ' dashboard-event-row-attention' : ''}`; %>
                    <% if (eventUrl) { %>
                      <a class="<%= eventRowClass %>" href="<%= eventUrl %>" aria-label="Открыть событие «<%= event.title %>» партии <%= event.code %>">
                    <% } else { %>
                      <article class="<%= eventRowClass %>">
                    <% } %>
                      <div class="dashboard-event-head">
                        <div class="dashboard-event-topline">
                          <time><%= event.timestamp ? new Intl.DateTimeFormat('ru-RU', { day: '2-digit', month: 'long', timeZone: dashboardTimeZone }).format(new Date(event.timestamp)) : 'Дата не указана' %><%= event.timestamp ? ` • ${new Intl.DateTimeFormat('ru-RU', { hour: '2-digit', minute: '2-digit', timeZone: dashboardTimeZone }).format(new Date(event.timestamp))}` : '' %></time>
                          <span><%= event.createdBy %></span>
                        </div>
                        <strong class="dashboard-event-title"><%= event.title %></strong>
                        <div class="dashboard-event-context">
                          <span class="dashboard-event-culture"><%= event.culture %></span>
                          <span class="dashboard-event-batch"><%= event.code %> · <%= event.stage %></span>
                        </div>
                      </div>
                      <div class="dashboard-event-divider" aria-hidden="true"></div>
                      <div class="dashboard-event-main">
                        <div class="dashboard-event-copy">
                          <% const details = eventDetails(event); %>
                          <% if (details.length) { %>
                            <div class="dashboard-event-details">
                              <% details.forEach((item) => { %>
                                <span class="dashboard-event-detail <%= isLongEventDetail(item) ? 'dashboard-event-detail-wide' : '' %>"><%= item %></span>
                              <% }) %>
                            </div>
                          <% } %>
                        </div>
                        <% if (event.previewPhoto) { %>
                          <span class="dashboard-event-photo" aria-hidden="true"><img src="<%= event.previewPhoto %>" alt="" loading="lazy"></span>
                        <% } %>
                      </div>
                    <% if (eventUrl) { %></a><% } else { %></article><% } %>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="dashboard-inline-empty">За выбранный период событий нет.</div>
              <% } %>
            </article>

            <article class="dashboard-card">
              <div class="dashboard-card-head"><div><h2>Проблемные партии</h2><p>Требуют внимания сейчас</p></div><a class="dashboard-card-link" href="/journal?category=problems">Все проблемы</a></div>
              <% if (dashboard.attentionBatches.length) { %>
                <div class="dashboard-attention-list">
                  <% dashboard.attentionBatches.forEach((batch) => { %>
                    <a href="/stages?batchId=<%= encodeURIComponent(batch.batchKey) %>" class="dashboard-attention-row">
                      <div><strong><%= batch.title %></strong><span><%= batch.code %> · <%= batch.stage %></span></div>
                      <div><b><%= batch.statusLabel %></b><span><%= batch.reason %> · риск: <%= batch.risk %></span><small><%= batch.latestProblemLabel %><%= batch.daysWithoutUpdate !== null ? ` · ${batch.daysWithoutUpdate} дн. без нового события` : '' %></small></div>
                    </a>
                  <% }) %>
                </div>
              <% } else { %><div class="dashboard-inline-empty">Нет партий, требующих внимания.</div><% } %>
            </article>
          </section>

          <section class="dashboard-grid dashboard-grid-secondary">
            <article class="dashboard-card dashboard-reports-card">
              <div class="dashboard-card-head"><div><h2>Последние отчеты</h2><p>Загружены за период</p></div><a href="/reports" class="dashboard-card-link">Все отчеты</a></div>
              <% if (dashboard.recentReports.length) { %>
                <div class="dashboard-reports">
                  <% dashboard.recentReports.forEach((report) => { %><a class="dashboard-report-row" href="/reports/<%= encodeURIComponent(report.reportId) %>"><div class="dashboard-report-main"><strong><%= report.author %></strong><span><%= report.role %> · <%= report.displayCreatedAt %></span></div><div class="dashboard-report-pills"><span><%= report.summary.cardsCount %> партий</span><span><%= report.summary.eventsCount %> событий</span><span><%= report.summary.photosCount %> фото</span><span><%= report.summary.problemsCount %> проблем</span></div></a><% }) %>
                </div>
              <% } else { %><div class="dashboard-inline-empty">За выбранный период отчетов нет.</div><% } %>
            </article>

            <article class="dashboard-card dashboard-gallery-card">
              <div class="dashboard-card-head"><div><h2>Последние фото</h2><p>Из событий за период</p></div></div>
              <% if (dashboard.recentPhotos.length) { %>
                <div class="dashboard-gallery dashboard-gallery-managed">
                  <% dashboard.recentPhotos.forEach((photo) => { %><button type="button" class="dashboard-thumb" data-photo-url="<%= photo.url %>" data-photo-label="<%= photo.label %>, <%= photo.dateLabel %>, <%= photo.createdBy %>"><span class="dashboard-thumb-image"><img src="<%= photo.url %>" alt="<%= photo.label %>" loading="lazy"></span><span class="dashboard-thumb-caption"><strong><%= photo.code %></strong><span><%= photo.eventTitle %> · <%= photo.dateLabel %></span><em><%= photo.createdBy %></em></span></button><% }) %>
                </div>
              <% } else { %><div class="dashboard-inline-empty">За выбранный период фотографий нет.</div><% } %>
            </article>
          </section>

          <% const metrics = Object.values(dashboard.productionMetrics); %>
          <% if (metrics.length) { %>
            <section class="dashboard-production" aria-label="Производственные показатели"><div><h2>Производственные показатели</h2><p>За период: <%= dashboard.period.label %></p></div><div class="dashboard-production-list"><% metrics.forEach((metric) => { %><article><span><%= metric.label %></span><strong><%= metric.value %> <small><%= metric.unit %></small></strong></article><% }) %></div></section>
          <% } %>

        </div>
      </section>
    <% } %>
  </main>
</div>
<%- include('partials/footer') %>
