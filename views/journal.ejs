<%- include('partials/head', { pageTitle }) %>
<% const filters = journal.filters; %>
<div class="app-shell">
  <%- include('partials/sidebar', { activePage: 'journal', showDashboardLink: journal.hasEvents }) %>

  <main class="app-main app-main-journal">
    <section class="global-journal" data-global-journal-page>
      <header class="global-journal-hero app-page-hero">
        <div>
          <h1>Журнал</h1>
        </div>
      </header>

      <section class="global-journal-layout">
        <aside class="global-journal-filter-panel">
          <h2>Фильтры</h2>
          <form class="global-journal-filters" method="get" action="/journal">
        <label class="global-journal-period">
          <span>Период</span>
          <select name="period" data-global-journal-period>
            <% journal.periodOptions.forEach((option) => { %>
              <option value="<%= option.value %>" <%= filters.period === option.value ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <div class="global-journal-custom-range" data-global-journal-custom-range <%= filters.period === 'custom' ? '' : 'hidden' %>>
          <label>
            <span>С</span>
            <input type="date" name="dateFrom" value="<%= filters.dateFrom %>" data-global-journal-date />
          </label>
          <label>
            <span>По</span>
            <input type="date" name="dateTo" value="<%= filters.dateTo %>" data-global-journal-date />
          </label>
        </div>
        <label>
          <span>Сотрудник</span>
          <select name="employee">
            <% journal.employeeOptions.forEach((option) => { %>
              <option value="<%= option.value %>" <%= filters.employee === option.value ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <label>
          <span>Быстрый фильтр</span>
          <select name="quick">
            <% journal.quickOptions.forEach((option) => { %>
              <option value="<%= option.value %>" <%= filters.quick === option.value ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <label>
          <span>Тип события</span>
          <select name="category">
            <% journal.categoryOptions.forEach((option) => { %>
              <option value="<%= option.value %>" <%= filters.category === option.value ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <label>
          <span>Стадия</span>
          <select name="stage">
            <% journal.stageOptions.forEach((option) => { %>
              <option value="<%= option.value %>" <%= filters.stage === option.value ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <label class="global-journal-search">
          <span>Партия</span>
          <input type="search" name="q" value="<%= filters.query %>" placeholder="Код, культура, вид или сорт" />
        </label>
            <button class="global-journal-apply" type="submit">Показать</button>

          </form>
        </aside>

        <section class="global-journal-results">

          <% if (journal.hasEvents) { %>
        <section class="global-journal-summary" aria-label="Сводка по найденным событиям">
          <span>Найдено действий: <strong><%= journal.summary.total %></strong></span>
          <span>Проблемных действий: <strong><%= journal.summary.problems %></strong></span>
          <span>Потеряно растений: <strong><%= journal.summary.lostPlants %></strong></span>
          <span>Продано растений: <strong><%= journal.summary.soldPlants %></strong></span>
          <span>Действий с фото: <strong><%= journal.summary.photos %></strong></span>
        </section>

        <% if (journal.hasResults) { %>
          <section class="global-journal-timeline" aria-label="Хронология событий">
            <% journal.groups.forEach((group) => { %>
              <section class="global-journal-day">
                <h2><%= group.label %></h2>
                <div class="global-journal-events">
                  <% group.events.forEach((event) => { %>
                    <article class="global-journal-event global-journal-event-<%= event.category %>">
                      <time datetime="<%= event.date %>"><%= event.timeLabel %></time>
                      <div class="global-journal-event-body">
                        <div class="global-journal-event-topline">
                          <div>
                            <span class="global-journal-category"><%= event.categoryLabel %></span>
                            <h3><%= event.title %></h3>
                          </div>
                          <% if (event.isImportant) { %><span class="global-journal-important">Важно</span><% } %>
                        </div>
                        <p class="global-journal-batch"><strong><%= event.culture %></strong><span><%= event.code %> · <%= event.stage %></span></p>
                        <p class="global-journal-author">Автор: <%= event.createdBy %></p>
                        <% if (event.details.length) { %>
                          <dl class="global-journal-details">
                            <% event.details.forEach((item) => { %><div><dt><%= item.label %></dt><dd><%= item.value %></dd></div><% }) %>
                          </dl>
                        <% } %>
                        <% if (event.comment) { %><p class="global-journal-comment"><%= event.comment %></p><% } %>
                        <% if (event.photos.length) { %>
                          <div class="global-journal-photos">
                            <% event.photos.forEach((photo, photoIndex) => { %>
                              <button type="button" class="global-journal-photo" data-photo-url="<%= photo %>" data-photo-label="<%= event.title %>, <%= event.code %>">
                                <img src="<%= photo %>" alt="Фото события <%= photoIndex + 1 %>" />
                              </button>
                            <% }) %>
                          </div>
                        <% } %>
                        <% if (event.cardId) { %><a class="global-journal-batch-link" href="<%= event.batchUrl %>">Открыть партию</a><% } %>
                      </div>
                    </article>
                  <% }) %>
                </div>
              </section>
            <% }) %>
          </section>
        <% } else { %>
          <section class="empty-state global-journal-empty"><h2>Ничего не найдено</h2><p>Попробуйте изменить период или фильтры.</p></section>
        <% } %>
          <% } else { %>
            <section class="empty-state global-journal-empty"><h2>Пока нет событий</h2><p>Они появятся после загрузки отчетов из Sadovnik Diary.</p></section>
          <% } %>
        </section>
      </section>
    </section>
  </main>
</div>
<%- include('partials/footer') %>
